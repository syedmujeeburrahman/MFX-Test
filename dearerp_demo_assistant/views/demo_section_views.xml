<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== SECTION FORM VIEW ==================== -->
    <record id="view_demo_section_form" model="ir.ui.view">
        <field name="name">dearerp.demo.section.form</field>
        <field name="model">dearerp.demo.section</field>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_demo_item_list)d" type="action"
                                class="oe_stat_button" icon="fa-list-ul"
                                context="{'default_section_id': active_id, 'search_default_section_id': active_id}">
                            <field name="item_count" widget="statistic" string="Content Items"/>
                        </button>
                        <button name="%(action_demo_faq_list)d" type="action"
                                class="oe_stat_button" icon="fa-question-circle"
                                context="{'default_section_id': active_id, 'search_default_section_id': active_id}"
                                invisible="section_type != 'faq'">
                            <field name="faq_count" widget="statistic" string="FAQs"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Section Title..."/>
                        </h1>
                        <field name="subtitle" placeholder="Add a subtitle..."/>
                    </div>
                    <group>
                        <group>
                            <field name="section_type"/>
                            <field name="icon"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active" invisible="1"/>
                            <field name="cover_image" widget="image" class="oe_avatar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Overview" name="overview">
                            <field name="description" placeholder="Write a section overview..."/>
                        </page>
                        <page string="Content Items" name="items">
                            <field name="item_ids" context="{'default_section_id': active_id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="icon"/>
                                    <field name="summary"/>
                                    <field name="highlight"/>
                                    <field name="badge_text"/>
                                </list>
                            </field>
                        </page>
                        <page string="FAQs" name="faqs" invisible="section_type != 'faq'">
                            <field name="faq_ids" context="{'default_section_id': active_id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="difficulty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ==================== SECTION LIST VIEW ==================== -->
    <record id="view_demo_section_list" model="ir.ui.view">
        <field name="name">dearerp.demo.section.list</field>
        <field name="model">dearerp.demo.section</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="section_type"/>
                <field name="subtitle"/>
                <field name="item_count"/>
                <field name="icon"/>
            </list>
        </field>
    </record>

    <!-- ==================== SECTION KANBAN VIEW (MAIN DASHBOARD CARDS) ==================== -->
    <record id="view_demo_section_kanban" model="ir.ui.view">
        <field name="name">dearerp.demo.section.kanban</field>
        <field name="model">dearerp.demo.section</field>
        <field name="arch" type="xml">
            <kanban class="o_demo_section_kanban" default_order="sequence" sample="1"
                    records_draggable="false" group_create="false">
                <templates>
                    <t t-name="card" class="o_demo_card flex-row p-0">
                        <div class="o_demo_card_left d-flex align-items-center justify-content-center"
                             t-attf-style="background: linear-gradient(135deg, #{['#667eea','#f093fb','#4facfe','#43e97b','#fa709a','#a18cd1'][record.color.value % 6] or '#667eea'}, #{['#764ba2','#f5576c','#00f2fe','#38f9d7','#fee140','#fbc2eb'][record.color.value % 6] or '#764ba2'});">
                            <i t-attf-class="fa #{record.icon.value or 'fa-star'} o_demo_card_icon"/>
                        </div>
                        <div class="o_demo_card_right flex-grow-1 p-3">
                            <div class="o_demo_card_header d-flex justify-content-between align-items-start mb-1">
                                <h3 class="o_demo_card_title mb-0">
                                    <field name="name"/>
                                </h3>
                                <span class="badge rounded-pill text-bg-primary o_demo_card_count">
                                    <t t-if="record.section_type.value == 'faq'">
                                        <field name="faq_count"/> FAQs
                                    </t>
                                    <t t-else="">
                                        <field name="item_count"/> items
                                    </t>
                                </span>
                            </div>
                            <p class="o_demo_card_subtitle text-muted mb-2">
                                <field name="subtitle"/>
                            </p>
                            <div class="o_demo_card_footer d-flex align-items-center gap-2">
                                <span class="badge rounded-pill o_demo_type_badge"
                                      t-attf-style="background: #{['#667eea','#f093fb','#4facfe','#43e97b','#fa709a','#a18cd1'][record.color.value % 6] or '#667eea'}; color: white;">
                                    <field name="section_type"/>
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ==================== SECTION SEARCH VIEW ==================== -->
    <record id="view_demo_section_search" model="ir.ui.view">
        <field name="name">dearerp.demo.section.search</field>
        <field name="model">dearerp.demo.section</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="section_type"/>
                <filter name="filter_introduction" string="Introduction"
                        domain="[('section_type','=','introduction')]"/>
                <filter name="filter_features" string="Features"
                        domain="[('section_type','=','features')]"/>
                <filter name="filter_comparison" string="Comparison"
                        domain="[('section_type','=','comparison')]"/>
                <filter name="filter_use_cases" string="Use Cases"
                        domain="[('section_type','=','use_cases')]"/>
                <filter name="filter_pricing" string="Pricing"
                        domain="[('section_type','=','pricing')]"/>
                <filter name="filter_faq" string="FAQs"
                        domain="[('section_type','=','faq')]"/>
                <group expand="false" string="Group By">
                    <filter name="group_by_type" string="Section Type"
                            context="{'group_by': 'section_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== SECTION ACTION ==================== -->
    <record id="action_demo_section" model="ir.actions.act_window">
        <field name="name">Demo Sections</field>
        <field name="res_model">dearerp.demo.section</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_demo_section_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first demo section
            </p>
            <p>
                Build your interactive demo presentation by adding sections
                for Introduction, Features, Comparisons, and more.
            </p>
        </field>
    </record>
</odoo>
