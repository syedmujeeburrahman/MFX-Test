<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== FAQ FORM VIEW ==================== -->
    <record id="view_demo_faq_form" model="ir.ui.view">
        <field name="name">dearerp.demo.faq.form</field>
        <field name="model">dearerp.demo.faq</field>
        <field name="arch" type="xml">
            <form string="FAQ">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Enter the question..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="section_id"/>
                            <field name="category"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="difficulty" widget="radio"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Answer" name="answer">
                            <field name="answer" placeholder="Write the answer here..."/>
                        </page>
                        <page string="Response Script" name="script">
                            <div class="alert alert-info mb-3" role="alert">
                                <i class="fa fa-lightbulb-o me-2"/>
                                Use this section to prepare a word-for-word script for
                                tough questions or common objections.
                            </div>
                            <field name="suggested_response"
                                   placeholder="Write a word-for-word response script..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== FAQ LIST VIEW ==================== -->
    <record id="view_demo_faq_list" model="ir.ui.view">
        <field name="name">dearerp.demo.faq.list</field>
        <field name="model">dearerp.demo.faq</field>
        <field name="arch" type="xml">
            <list string="FAQs" default_order="sequence">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category"/>
                <field name="difficulty" decoration-danger="difficulty == 'hard'"
                       decoration-warning="difficulty == 'medium'"
                       decoration-success="difficulty == 'easy'"
                       widget="badge"/>
                <field name="section_id"/>
            </list>
        </field>
    </record>

    <!-- ==================== FAQ KANBAN VIEW ==================== -->
    <record id="view_demo_faq_kanban" model="ir.ui.view">
        <field name="name">dearerp.demo.faq.kanban</field>
        <field name="model">dearerp.demo.faq</field>
        <field name="arch" type="xml">
            <kanban class="o_demo_faq_kanban" default_order="sequence"
                    records_draggable="false" group_create="false">
                <field name="id"/>
                <field name="name"/>
                <field name="category"/>
                <field name="difficulty"/>
                <field name="answer"/>
                <templates>
                    <t t-name="card" class="o_demo_faq_card p-0">
                        <div class="o_demo_faq_card_body p-3">
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="fa fa-question-circle fa-lg"
                                   style="color: #667eea; margin-top: 2px;"/>
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-start justify-content-between gap-1">
                                        <strong class="o_demo_faq_question">
                                            <field name="name"/>
                                        </strong>
                                        <span t-attf-class="badge rounded-pill #{record.difficulty.raw_value == 'hard' ? 'text-bg-danger' : record.difficulty.raw_value == 'medium' ? 'text-bg-warning' : 'text-bg-success'}">
                                            <field name="difficulty"/>
                                        </span>
                                    </div>
                                    <span class="badge text-bg-light text-muted mt-1">
                                        <field name="category"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ==================== FAQ SEARCH VIEW ==================== -->
    <record id="view_demo_faq_search" model="ir.ui.view">
        <field name="name">dearerp.demo.faq.search</field>
        <field name="model">dearerp.demo.faq</field>
        <field name="arch" type="xml">
            <search string="Search FAQs">
                <field name="name"/>
                <field name="category"/>
                <filter name="filter_easy" string="Easy"
                        domain="[('difficulty','=','easy')]"/>
                <filter name="filter_medium" string="Moderate"
                        domain="[('difficulty','=','medium')]"/>
                <filter name="filter_hard" string="Tough"
                        domain="[('difficulty','=','hard')]"/>
                <separator/>
                <filter name="filter_general" string="General"
                        domain="[('category','=','general')]"/>
                <filter name="filter_technical" string="Technical"
                        domain="[('category','=','technical')]"/>
                <filter name="filter_pricing_cat" string="Pricing"
                        domain="[('category','=','pricing')]"/>
                <filter name="filter_security" string="Security"
                        domain="[('category','=','security')]"/>
                <filter name="filter_comparison_cat" string="Comparison"
                        domain="[('category','=','comparison')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_category" string="Category"
                            context="{'group_by': 'category'}"/>
                    <filter name="group_by_difficulty" string="Difficulty"
                            context="{'group_by': 'difficulty'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== FAQ ACTION ==================== -->
    <record id="action_demo_faq_list" model="ir.actions.act_window">
        <field name="name">FAQs &amp; Objections</field>
        <field name="res_model">dearerp.demo.faq</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_demo_faq_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first FAQ
            </p>
            <p>
                Prepare answers for common prospect questions and objections.
            </p>
        </field>
    </record>
</odoo>
