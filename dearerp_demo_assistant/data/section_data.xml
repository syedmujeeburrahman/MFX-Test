<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ==================== SECTION 1: INTRODUCTION ==================== -->
        <record id="section_introduction" model="dearerp.demo.section">
            <field name="name">Introduction to DearERP</field>
            <field name="sequence">1</field>
            <field name="section_type">introduction</field>
            <field name="icon">fa-rocket</field>
            <field name="color">0</field>
            <field name="subtitle">Your AI-Powered Odoo Development Partner</field>
            <field name="description"><![CDATA[
                <div style="font-size: 15px; line-height: 1.8; color: #444;">
                    <p><strong>DearERP</strong> is an AI-powered platform purpose-built for Odoo ERP customization and module development.
                    Unlike generic AI coding tools, DearERP deeply understands the Odoo framework — its ORM, view architecture,
                    security model, and module lifecycle — delivering production-ready custom modules in minutes, not days.</p>
                    <p>Whether you need custom reports, workflow automations, new business modules, or complex integrations,
                    DearERP handles it end-to-end: from scaffolding and coding to validation, testing, and deployment-ready output.</p>
                </div>
            ]]></field>
        </record>

        <!-- ==================== SECTION 2: FEATURES ==================== -->
        <record id="section_features" model="dearerp.demo.section">
            <field name="name">Features &amp; Functionalities</field>
            <field name="sequence">2</field>
            <field name="section_type">features</field>
            <field name="icon">fa-th-large</field>
            <field name="color">1</field>
            <field name="subtitle">Everything you need for Odoo development, powered by AI</field>
            <field name="description"><![CDATA[
                <div style="font-size: 15px; line-height: 1.8; color: #444;">
                    <p>DearERP combines deep Odoo expertise with cutting-edge AI capabilities to provide
                    a comprehensive suite of tools for module development, customization, and deployment.</p>
                </div>
            ]]></field>
        </record>

        <!-- ==================== SECTION 3: COMPARISON ==================== -->
        <record id="section_comparison" model="dearerp.demo.section">
            <field name="name">AI Tool Comparison</field>
            <field name="sequence">3</field>
            <field name="section_type">comparison</field>
            <field name="icon">fa-balance-scale</field>
            <field name="color">2</field>
            <field name="subtitle">How DearERP stacks up against other AI tools</field>
            <field name="description"><![CDATA[
                <div style="font-size: 15px; line-height: 1.8; color: #444;">
                    <p>See how DearERP's specialized Odoo expertise compares to general-purpose
                    AI coding tools. While other tools can write generic Python, DearERP speaks fluent Odoo.</p>
                </div>
            ]]></field>
        </record>

        <!-- ==================== SECTION 4: USE CASES ==================== -->
        <record id="section_use_cases" model="dearerp.demo.section">
            <field name="name">Complex Use Cases</field>
            <field name="sequence">4</field>
            <field name="section_type">use_cases</field>
            <field name="icon">fa-puzzle-piece</field>
            <field name="color">3</field>
            <field name="subtitle">Real-world scenarios that showcase DearERP's power</field>
            <field name="description"><![CDATA[
                <div style="font-size: 15px; line-height: 1.8; color: #444;">
                    <p>These are complex, real-world Odoo customization scenarios that typically take
                    developers days or weeks to implement — but DearERP handles them efficiently and accurately.</p>
                </div>
            ]]></field>
        </record>

        <!-- ==================== SECTION 5: PRICING ==================== -->
        <record id="section_pricing" model="dearerp.demo.section">
            <field name="name">Pricing &amp; Plans</field>
            <field name="sequence">5</field>
            <field name="section_type">pricing</field>
            <field name="icon">fa-tags</field>
            <field name="color">4</field>
            <field name="subtitle">Flexible plans for every team size and need</field>
            <field name="description"><![CDATA[
                <div style="font-size: 15px; line-height: 1.8; color: #444;">
                    <p>Choose the plan that fits your needs. All plans include core DearERP capabilities
                    with additional features and capacity as you scale.</p>
                </div>
            ]]></field>
        </record>

        <!-- ==================== SECTION 6: FAQ ==================== -->
        <record id="section_faq" model="dearerp.demo.section">
            <field name="name">FAQs &amp; Objection Handling</field>
            <field name="sequence">6</field>
            <field name="section_type">faq</field>
            <field name="icon">fa-comments</field>
            <field name="color">5</field>
            <field name="subtitle">Prepared answers for every prospect question</field>
            <field name="description"><![CDATA[
                <div style="font-size: 15px; line-height: 1.8; color: #444;">
                    <p>A comprehensive collection of frequently asked questions and tough objections
                    with well-prepared answers to help you handle any discussion confidently.</p>
                </div>
            ]]></field>
        </record>
    </data>
</odoo>
