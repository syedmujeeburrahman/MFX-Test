<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Sale Order Form View -->
    <record id="sale_order_form_inherit_mobile" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.mobile</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="mobile" widget="phone"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Sale Order Form View - Add Description -->
    <record id="sale_order_form_inherit_description" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.description</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="x_description" placeholder="Enter description or notes for this quotation/order..."/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Sale Order List View -->
    <record id="sale_order_list_inherit_mobile" model="ir.ui.view">
        <field name="name">sale.order.list.inherit.mobile</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="mobile" optional="hide"/>
                <field name="x_description" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
