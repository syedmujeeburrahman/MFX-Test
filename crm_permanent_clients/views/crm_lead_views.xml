<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crm_lead_form_permanent_client" model="ir.ui.view">
        <field name="name">crm.lead.form.permanent.client</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_mark_as_permanent_client"
                        type="object"
                        string="Mark as Permanent Client"
                        class="btn-secondary"
                        invisible="type != 'opportunity'"/>
            </xpath>
        </field>
    </record>

</odoo>
