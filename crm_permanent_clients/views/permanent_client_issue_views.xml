<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_permanent_client_issue_list" model="ir.ui.view">
        <field name="name">x_erp.permanent_client_issue.list</field>
        <field name="model">x_erp.permanent_client_issue</field>
        <field name="arch" type="xml">
            <list string="Client Issues &amp; Queries"
                  decoration-info="state == 'new'"
                  decoration-warning="state in ('in_progress','waiting')"
                  decoration-success="state == 'resolved'"
                  decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="issue_type"/>
                <field name="priority" widget="priority"/>
                <field name="user_id"/>
                <field name="date_open"/>
                <field name="date_closed" optional="hide"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_permanent_client_issue_form" model="ir.ui.view">
        <field name="name">x_erp.permanent_client_issue.form</field>
        <field name="model">x_erp.permanent_client_issue</field>
        <field name="arch" type="xml">
            <form string="Client Issue">
                <header>
                    <button name="action_start" type="object" string="Start" class="btn-primary"
                            invisible="state != 'new'"/>
                    <button name="action_wait_client" type="object" string="Wait on Client"
                            invisible="state not in ('new','in_progress')"/>
                    <button name="action_resolve" type="object" string="Mark Resolved" class="btn-success"
                            invisible="state in ('resolved','closed')"/>
                    <button name="action_close" type="object" string="Close"
                            invisible="state == 'closed'"/>
                    <button name="action_reopen" type="object" string="Reopen"
                            invisible="state not in ('resolved','closed')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,in_progress,waiting,resolved,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Issue subject..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" options="{'no_create': True}"/>
                            <field name="issue_type"/>
                            <field name="priority" widget="priority"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="date_open"/>
                            <field name="date_closed" invisible="state not in ('resolved','closed')"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the issue or query..."/>
                        </page>
                        <page string="Resolution" name="resolution" invisible="state not in ('resolved','closed')">
                            <field name="resolution" placeholder="How was it resolved?"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_permanent_client_issue_kanban" model="ir.ui.view">
        <field name="name">x_erp.permanent_client_issue.kanban</field>
        <field name="model">x_erp.permanent_client_issue</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="priority"/>
                <field name="user_id"/>
                <field name="state"/>
                <field name="issue_type"/>
                <templates>
                    <t t-name="card">
                        <div class="p-2">
                            <strong><field name="name"/></strong>
                            <div><i class="fa fa-user"/> <field name="partner_id"/></div>
                            <div class="mt-1">
                                <field name="issue_type"/>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="mt-1 text-muted">
                                <field name="user_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_permanent_client_issue_search" model="ir.ui.view">
        <field name="name">x_erp.permanent_client_issue.search</field>
        <field name="model">x_erp.permanent_client_issue</field>
        <field name="arch" type="xml">
            <search string="Client Issues">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <filter name="my_issues" string="My Issues"
                        domain="[('user_id','=',uid)]"/>
                <separator/>
                <filter name="open" string="Open"
                        domain="[('state','in',('new','in_progress','waiting'))]"/>
                <filter name="new" string="New" domain="[('state','=','new')]"/>
                <filter name="in_progress" string="In Progress" domain="[('state','=','in_progress')]"/>
                <filter name="waiting" string="Waiting on Client" domain="[('state','=','waiting')]"/>
                <filter name="resolved" string="Resolved" domain="[('state','=','resolved')]"/>
                <filter name="closed" string="Closed" domain="[('state','=','closed')]"/>
                <separator/>
                <filter name="urgent" string="Urgent" domain="[('priority','=','3')]"/>
                <group>
                    <filter name="group_by_partner" string="Client" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_type" string="Type" context="{'group_by': 'issue_type'}"/>
                    <filter name="group_by_user" string="Assigned To" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_permanent_client_issues" model="ir.actions.act_window">
        <field name="name">Client Issues &amp; Queries</field>
        <field name="res_model">x_erp.permanent_client_issue</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_permanent_client_issue_search"/>
        <field name="context">{'search_default_open': 1, 'search_default_group_by_partner': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Log a new issue or query from a permanent client</p>
        </field>
    </record>

</odoo>
