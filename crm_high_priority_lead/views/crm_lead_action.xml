<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard action: shows every high-priority lead/opportunity -->
    <record id="action_crm_high_priority_leads" model="ir.actions.act_window">
        <field name="name">High-Priority Leads</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('x_high_priority_effective', '=', True)]</field>
        <field name="context">{
            'search_default_filter_high_priority_any': 1,
            'default_x_is_high_priority': True,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No high-priority leads yet.
            </p>
            <p>
                Open any lead or opportunity and click
                <b><i class="fa fa-star"/> Mark High Priority</b> in the header
                to bring it into this focused view.
            </p>
        </field>
    </record>

    <!-- Dashboard action for opportunities only (pipeline) -->
    <record id="action_crm_high_priority_pipeline" model="ir.actions.act_window">
        <field name="name">High-Priority Pipeline</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('x_high_priority_effective', '=', True), ('type', '=', 'opportunity')]</field>
        <field name="context">{
            'default_type': 'opportunity',
            'default_x_is_high_priority': True,
            'search_default_filter_high_priority_any_opp': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Nothing in the high-priority pipeline yet.
            </p>
        </field>
    </record>

</odoo>
