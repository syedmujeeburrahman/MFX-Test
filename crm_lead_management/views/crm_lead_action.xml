<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard Action: Leads by Stage (Pivot) -->
    <record id="crm_lead_report_action_pivot" model="ir.actions.act_window">
        <field name="name">Pipeline Analysis</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">pivot,graph</field>
        <field name="context">{
            'search_default_groupby_lead_type': 1,
        }</field>
    </record>

    <!-- Menu for Pipeline Analysis under CRM Reporting -->
    <menuitem id="menu_crm_lead_report_analysis"
              name="Pipeline Analysis"
              parent="crm.crm_menu_report"
              action="crm_lead_report_action_pivot"
              sequence="20"/>

</odoo>
