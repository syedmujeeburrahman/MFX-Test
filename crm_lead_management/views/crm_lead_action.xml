<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Override the main CRM Pipeline action to use our custom ungrouped kanban.
        This replaces the kanban view in the pipeline so when user selects a stage
        from the searchpanel dropdown, only those leads show (no stage columns).
    -->

    <!-- Override the existing kanban view binding in the main Pipeline action -->
    <record id="crm.crm_lead_action_pipeline_view_kanban" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="crm.crm_lead_action_pipeline"/>
        <field name="view_id" ref="view_crm_lead_kanban_by_stage"/>
        <field name="view_mode">kanban</field>
        <field name="sequence">0</field>
    </record>

    <!-- Also keep our separate Leads by Stage action -->
    <record id="crm_lead_action_by_stage" model="ir.actions.act_window">
        <field name="name">Leads by Stage</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form,graph,pivot,calendar</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No leads found for the selected stage.
            </p>
            <p>Select a stage from the left panel to view leads.</p>
        </field>
    </record>

    <record id="crm_lead_action_by_stage_view_kanban" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="crm_lead_action_by_stage"/>
        <field name="view_id" ref="view_crm_lead_kanban_by_stage"/>
        <field name="view_mode">kanban</field>
        <field name="sequence">0</field>
    </record>

    <record id="crm_lead_action_by_stage_view_list" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="crm_lead_action_by_stage"/>
        <field name="view_mode">list</field>
        <field name="sequence">1</field>
    </record>

    <record id="crm_lead_action_by_stage_view_form" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="crm_lead_action_by_stage"/>
        <field name="view_mode">form</field>
        <field name="sequence">2</field>
    </record>

    <!-- Menu: Leads by Stage under CRM Sales -->
    <menuitem id="menu_crm_leads_by_stage"
              name="Leads by Stage"
              parent="crm.crm_menu_sales"
              action="crm_lead_action_by_stage"
              sequence="5"/>

    <!-- Dashboard Action: Pipeline Analysis (Pivot) -->
    <record id="crm_lead_report_action_pivot" model="ir.actions.act_window">
        <field name="name">Pipeline Analysis</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">pivot,graph</field>
        <field name="context">{
            'search_default_groupby_lead_type': 1,
        }</field>
    </record>

    <!-- Menu for Pipeline Analysis under CRM Reporting -->
    <menuitem id="menu_crm_lead_report_analysis"
              name="Pipeline Analysis"
              parent="crm.crm_menu_report"
              action="crm_lead_report_action_pivot"
              sequence="20"/>

</odoo>
