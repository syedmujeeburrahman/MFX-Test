<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Opportunity Search View -->
    <record id="view_crm_case_opportunities_filter_inherit" model="ir.ui.view">
        <field name="name">crm.lead.search.opportunity.inherit.crm_lead_management</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="arch" type="xml">

            <!-- Add Lead Type filters -->
            <xpath expr="//filter[@name='won']" position="before">
                <separator/>
                <filter string="Hot Leads" name="filter_hot"
                        domain="[('x_lead_type', '=', 'hot')]"/>
                <filter string="Warm Leads" name="filter_warm"
                        domain="[('x_lead_type', '=', 'warm')]"/>
                <filter string="Cold Leads" name="filter_cold"
                        domain="[('x_lead_type', '=', 'cold')]"/>
                <separator/>
                <filter string="Follow-up Today" name="filter_followup_today"
                        domain="[('x_next_followup_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Follow-up Overdue" name="filter_followup_overdue"
                        domain="[('x_next_followup_date', '&lt;', context_today().strftime('%Y-%m-%d')), ('x_next_followup_date', '!=', False)]"/>
                <filter string="Follow-up This Week" name="filter_followup_week"
                        domain="[('x_next_followup_date', '&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d')), ('x_next_followup_date', '&lt;=', (context_today() + datetime.timedelta(days=6 - context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <separator/>
            </xpath>

            <!-- Add Group By options -->
            <xpath expr="//group" position="inside">
                <filter string="Lead Type" name="groupby_lead_type"
                        context="{'group_by': 'x_lead_type'}"/>
                <filter string="Next Follow-up" name="groupby_followup"
                        context="{'group_by': 'x_next_followup_date'}"/>
                <filter string="Country" name="groupby_country"
                        context="{'group_by': 'country_id'}"/>
                <filter string="State" name="groupby_state"
                        context="{'group_by': 'state_id'}"/>
                <filter string="City" name="groupby_city"
                        context="{'group_by': 'city'}"/>
                <filter string="Source" name="groupby_source"
                        context="{'group_by': 'source_id'}"/>
            </xpath>

        </field>
    </record>

    <!-- Inherit Lead Search View -->
    <record id="view_crm_case_leads_filter_inherit" model="ir.ui.view">
        <field name="name">crm.lead.search.lead.inherit.crm_lead_management</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_leads_filter"/>
        <field name="arch" type="xml">

            <xpath expr="//group" position="inside">
                <filter string="Lead Type" name="groupby_lead_type"
                        context="{'group_by': 'x_lead_type'}"/>
                <filter string="Next Follow-up" name="groupby_followup"
                        context="{'group_by': 'x_next_followup_date'}"/>
                <filter string="Country" name="groupby_country"
                        context="{'group_by': 'country_id'}"/>
                <filter string="Source" name="groupby_source"
                        context="{'group_by': 'source_id'}"/>
            </xpath>

        </field>
    </record>

</odoo>
