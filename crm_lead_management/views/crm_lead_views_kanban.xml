<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Kanban View for Opportunities -->
    <record id="view_crm_lead_kanban_inherit" model="ir.ui.view">
        <field name="name">crm.lead.kanban.inherit.crm_lead_management</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_lead_kanban"/>
        <field name="arch" type="xml">

            <!-- Add lead type badge in the kanban card footer next to priority -->
            <xpath expr="//field[@name='priority']" position="after">
                <field name="x_lead_type" invisible="1"/>
                <span class="ms-1">
                    <span t-if="record.x_lead_type.raw_value == 'hot'"
                          class="badge text-bg-danger">Hot</span>
                    <span t-if="record.x_lead_type.raw_value == 'warm'"
                          class="badge text-bg-warning">Warm</span>
                    <span t-if="record.x_lead_type.raw_value == 'cold'"
                          class="badge text-bg-info">Cold</span>
                </span>
            </xpath>

        </field>
    </record>

</odoo>
