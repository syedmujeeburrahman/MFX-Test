<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit crm.lead Form View -->
    <record id="crm_lead_view_form_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.crm_lead_management</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- Add Lead Type badge next to priority stars -->
            <xpath expr="//field[@name='priority']" position="after">
                <field name="x_lead_type" widget="badge"
                       decoration-danger="x_lead_type == 'hot'"
                       decoration-warning="x_lead_type == 'warm'"
                       decoration-info="x_lead_type == 'cold'"/>
            </xpath>

            <!-- Add Next Follow-up Date in the main info area -->
            <xpath expr="//field[@name='date_deadline']" position="after">
                <field name="x_next_followup_date"/>
            </xpath>

            <!-- Add Country field in the lead info section -->
            <xpath expr="//field[@name='phone']" position="after">
                <field name="country_id" placeholder="Country"
                       options="{'no_create': True, 'no_open': True}"/>
            </xpath>

        </field>
    </record>

</odoo>
