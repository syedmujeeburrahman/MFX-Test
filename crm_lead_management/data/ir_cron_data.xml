<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Cron: Daily Follow-up Reminder -->
    <record id="ir_cron_followup_reminder" model="ir.cron">
        <field name="name">CRM: Follow-up Reminder</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">model._cron_followup_reminder()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>
