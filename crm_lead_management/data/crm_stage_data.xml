<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        CRM Pipeline Stages for Lead Management.
        All 6 stages already exist on the instance from initial install.
        This file only creates stages owned by this module.
        We do NOT reference crm.stage_lead* XML IDs to avoid missing record errors.
        The existing default stages were already renamed during first install.
    -->

    <!-- Stage 4: Demo Completed -->
    <record id="stage_demo_completed" model="crm.stage">
        <field name="name">Demo Completed</field>
        <field name="sequence">4</field>
        <field name="is_won" eval="False"/>
        <field name="fold" eval="False"/>
    </record>

    <!-- Stage 5: Negotiation -->
    <record id="stage_negotiation" model="crm.stage">
        <field name="name">Negotiation</field>
        <field name="sequence">5</field>
        <field name="is_won" eval="False"/>
        <field name="fold" eval="False"/>
    </record>

</odoo>
