<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        The previous daily reset cron has been removed. Once a lead is marked
        as contacted, the status is permanent until the user explicitly
        unmarks it. We keep the record id defined but deactivated so existing
        installs get the job disabled on upgrade.
    -->
    <record id="ir_cron_reset_contacted_today" model="ir.cron">
        <field name="name">CRM: Reset Daily Contact Tracker (DISABLED)</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">pass</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="False"/>
    </record>

</odoo>
