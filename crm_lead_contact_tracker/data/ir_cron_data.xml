<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Daily Cron: Reset 'Contacted Today' flags at midnight -->
    <record id="ir_cron_reset_contacted_today" model="ir.cron">
        <field name="name">CRM: Reset Daily Contact Tracker</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">model._cron_reset_contacted_today()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>
