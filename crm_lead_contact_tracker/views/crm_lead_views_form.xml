<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit CRM Lead Form View (Odoo 19: crm.crm_lead_view_form) -->
    <record id="view_crm_lead_form_inherit_contact_tracker" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.contact_tracker</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- Green success banner at top of sheet when contacted -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-success text-center o_contacted_banner"
                     invisible="not x_is_contacted_today"
                     role="status">
                    <strong>
                        <i class="fa fa-check-circle"/> CONTACTED
                    </strong>
                    — Handled by
                    <field name="x_contacted_by" readonly="1" widget="many2one_avatar_user" class="d-inline"/>
                    on <field name="x_contacted_date" readonly="1" widget="datetime" class="d-inline"/>
                </div>
            </xpath>

            <!-- Mark / Unmark buttons inside the existing header -->
            <xpath expr="//header/field[@name='stage_id']" position="before">
                <button name="action_mark_contacted"
                        type="object"
                        string="Mark as Contacted"
                        class="btn-success"
                        icon="fa-check-circle"
                        invisible="x_is_contacted_today"
                        confirm="Mark this lead as contacted for today?"/>
                <button name="action_unmark_contacted"
                        type="object"
                        string="Unmark Contacted"
                        class="btn-secondary"
                        icon="fa-undo"
                        invisible="not x_is_contacted_today"/>
            </xpath>

            <!-- Stat button in button box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" icon="fa-check-circle"
                        name="action_mark_contacted" type="object"
                        invisible="x_is_contacted_today">
                    <div class="o_stat_info">
                        <span class="o_stat_text text-danger fw-bold">Pending</span>
                    </div>
                </button>
                <button class="oe_stat_button" icon="fa-check-circle"
                        invisible="not x_is_contacted_today">
                    <div class="o_stat_info">
                        <span class="o_stat_value text-success">
                            <field name="x_contact_count"/>
                        </span>
                        <span class="o_stat_text text-success">Contacted</span>
                    </div>
                </button>
            </xpath>

            <!-- Contact tracking fields in the notebook Extra Info page -->
            <xpath expr="//page[@name='extra']" position="inside">
                <group string="Contact Tracking" name="contact_tracking">
                    <group>
                        <field name="x_is_contacted_today" widget="boolean_toggle"/>
                        <field name="x_contacted_note"
                               placeholder="Add a note before marking..."
                               invisible="x_is_contacted_today"/>
                    </group>
                    <group>
                        <field name="x_contacted_date" readonly="1"/>
                        <field name="x_contacted_by" readonly="1"/>
                        <field name="x_contact_count" readonly="1"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
