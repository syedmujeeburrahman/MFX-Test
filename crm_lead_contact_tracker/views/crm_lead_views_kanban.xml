<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit CRM Leads Kanban View (Odoo 19: crm.crm_case_kanban_view_leads) -->
    <record id="view_crm_lead_kanban_leads_inherit_contact_tracker" model="ir.ui.view">
        <field name="name">crm.lead.kanban.leads.inherit.contact_tracker</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="arch" type="xml">
            <!-- Add class to kanban for CSS targeting -->
            <xpath expr="//kanban" position="attributes">
                <attribute name="class">o_crm_contact_tracker_kanban</attribute>
            </xpath>
            <!-- Add fields before templates so they're available in card -->
            <xpath expr="//templates" position="before">
                <field name="x_is_contacted_today"/>
            </xpath>
            <!-- Add contacted status strip at the TOP of the kanban card -->
            <xpath expr="//widget[@id='lost_ribbon']" position="before">
                <div t-if="record.x_is_contacted_today.raw_value"
                     class="o_contacted_top_strip o_contacted_strip_yes">
                    <i class="fa fa-check-circle me-1"/>Contacted
                </div>
                <div t-else=""
                     class="o_contacted_top_strip o_contacted_strip_no">
                    <i class="fa fa-clock-o me-1"/>Not Contacted
                </div>
            </xpath>
        </field>
    </record>

    <!-- Inherit CRM Opportunity Kanban View (Odoo 19: crm.view_crm_lead_kanban) -->
    <record id="view_crm_lead_kanban_opps_inherit_contact_tracker" model="ir.ui.view">
        <field name="name">crm.lead.kanban.opps.inherit.contact_tracker</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_lead_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="class">o_crm_contact_tracker_kanban</attribute>
            </xpath>
            <xpath expr="//templates" position="before">
                <field name="x_is_contacted_today"/>
            </xpath>
            <!-- Add contacted status strip at the TOP of leads kanban card -->
            <xpath expr="//t[@t-name='card']/field[@name='name']" position="before">
                <div t-if="record.x_is_contacted_today.raw_value"
                     class="o_contacted_top_strip o_contacted_strip_yes">
                    <i class="fa fa-check-circle me-1"/>Contacted
                </div>
                <div t-else=""
                     class="o_contacted_top_strip o_contacted_strip_no">
                    <i class="fa fa-clock-o me-1"/>Not Contacted
                </div>
            </xpath>
        </field>
    </record>

</odoo>
